   "source": [
    "adata_traj = build_dendrogram(adata_traj)\n",
    "\n",
    "# Rename numeric IDs to the dominant cell type at each branch endpoint\n",
    "adata_traj = rename_milestones_by_celltype(adata_traj, ANNOTATION_COL)\n",
    "\n",
    "# Use these names in MILESTONES_TO_ANALYZE and ROOT_CLUSTER in Section 29\n",
    "print(\"\\nAvailable milestones (use these names in Section 29):\")\n",
    "print(sorted(adata_traj.obs[\"milestones\"].unique().tolist()))\n",
    "\n",
    "scf.pl.dendrogram(adata_traj, color=\"milestones\", legend_loc=\"on data\", save=\"_milestones.pdf\")\n",
    "print(\"\\nSECTION 28 COMPLETE — see milestone names above\")"
   ]
  },
  {
