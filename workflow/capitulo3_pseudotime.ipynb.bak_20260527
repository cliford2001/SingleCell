    "\n",
    "sc.pl.umap(\n",
    "    adata_sub,\n",
    "    color              = ANNOTATION_COL,\n",
    "    legend_loc         = \"on data\",\n",
    "    legend_fontsize    = 9,\n",
    "    legend_fontoutline = 3,\n",
    "    frameon            = False,\n",
    "    show               = True,\n",
    "    save               = \"_selection.png\",\n",
    ")\n",
